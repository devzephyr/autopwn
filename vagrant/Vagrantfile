# =============================================================================
# Neutron Enterprise Lab — Vagrant topology replication
# RIS602 Network Penetration Testing — Seneca Polytechnic
#
# Provider:  VirtualBox only
# Networks:  Four isolated VirtualBox networks (VLANs) plus one host-only
#            management network so `vagrant ssh` continues to work.
#
# VLAN layout
#   vlan10  172.16.10.0/24  — Internal: DC, workstations, private DNS
#   vlan20  172.16.20.0/24  — Server: containers (web/db/NFS/ERP)
#   vlan30  172.16.30.0/24  — DMZ: pubdns, jumpbox, VPN server
#   vlan40  172.16.40.0/24  — External Simulation: remoteuser, Kali
#   mgmt    172.16.99.0/24  — pfSense management (host-only, never routed)
#
# VM inventory
#   pfsense     172.16.99.1 + one address per VLAN (router/firewall)
#   dc01        172.16.10.10  Windows Server 2022 — AD DS, ADCS, DNS
#   adminws     172.16.10.20  Windows 10 — domain-joined, hradmin
#   userws      172.16.10.21  Windows 10 — domain-joined, jsmith
#   privdns     172.16.10.53  Ubuntu — Bind9 authoritative for neutron.local
#   containers  172.16.20.10  Ubuntu — Docker Compose (corpweb/esite/odoo/nc/db)
#   pubdns      172.16.30.10  Ubuntu — Bind9 public forwarding (NXDOMAIN for internal)
#   jumpbox     172.16.30.20  Ubuntu — SSH+xRDP, saved domain creds (postex)
#   vpn         172.16.30.30  Ubuntu — OpenVPN PKI, pushes privdns to VPN clients
#   remoteuser  172.16.40.10  Ubuntu — OpenVPN client, simulates external user
#   kali        172.16.40.50  Kali Linux — autopwn attacker
#
# Boot sequence
#   dc01starts first (primary, order: 1).  All others start in parallel after.
#   After vagrant up: run dc01-pass2 and workstation joins (see below).
#
# DC two-pass provisioning
#   vagrant up
#     → runs dc01-pass1 (AD DS install + reboot)
#   vagrant provision dc01 --provision-with dc01-pass2
#     → run once DC has finished rebooting (~3-5 min)
#     → configures DNS records, users, ADCS PKI, IIS cert page
#
# Workstation domain join (after dc01-pass2 is complete)
#   vagrant provision adminws --provision-with adminws-join
#   vagrant provision userws  --provision-with userws-join
#
# Synced folders are disabled on every VM for performance.
# =============================================================================

Vagrant.require_version ">= 2.3.0"

# ---------------------------------------------------------------------------
# IP address constants — every address in this file comes from here.
# ---------------------------------------------------------------------------

# pfSense gateway addresses, one per interface
PFSENSE_MGMT   = "172.16.99.1"   # LAN (host-only mgmt) — web GUI
PFSENSE_VLAN10 = "172.16.10.1"   # OPT1 — internal segment
PFSENSE_VLAN20 = "172.16.20.1"   # OPT2 — server segment
PFSENSE_VLAN30 = "172.16.30.1"   # OPT3 — DMZ segment
PFSENSE_VLAN40 = "172.16.40.1"   # OPT4 — external simulation segment

# VLAN10 — Internal
DC01_IP        = "172.16.10.10"
ADMINWS_IP     = "172.16.10.20"
USERWS_IP      = "172.16.10.21"
PRIVDNS_IP     = "172.16.10.53"

# VLAN20 — Server / container host
CONTAINERS_IP  = "172.16.20.10"

# VLAN30 — DMZ
PUBDNS_IP      = "172.16.30.10"
JUMPBOX_IP     = "172.16.30.20"
VPN_IP         = "172.16.30.30"

# VLAN40 — External simulation
REMOTEUSER_IP  = "172.16.40.10"
KALI_IP        = "172.16.40.50"

# VirtualBox internal network names
NET_VLAN10 = "neutron-vlan10"
NET_VLAN20 = "neutron-vlan20"
NET_VLAN30 = "neutron-vlan30"
NET_VLAN40 = "neutron-vlan40"

# ---------------------------------------------------------------------------
# Vagrant configuration
# ---------------------------------------------------------------------------

Vagrant.configure("2") do |config|

  config.vbguest.auto_update = false if Vagrant.has_plugin?("vagrant-vbguest")

  # ==========================================================================
  # pfSense — Core router / firewall
  #
  # Interface map (VirtualBox adapter → pfSense vtnet):
  #   adapter 1  vtnet0  NAT       — WAN, outbound internet
  #   adapter 2  vtnet1  host-only — LAN / mgmt (172.16.99.1)
  #   adapter 3  vtnet2  internal  — OPT1 / vlan10 (172.16.10.1)
  #   adapter 4  vtnet3  internal  — OPT2 / vlan20 (172.16.20.1)
  #   adapter 5  vtnet4  internal  — OPT3 / vlan30 (172.16.30.1)
  #   adapter 6  vtnet5  internal  — OPT4 / vlan40 (172.16.40.1)
  # ==========================================================================
  config.vm.define "pfsense" do |pf|
    pf.vm.box      = "nicholaswilde/pfsense"
    pf.vm.hostname = "pfsense"
    pf.vm.synced_folder ".", "/vagrant", disabled: true

    pf.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-pfsense"
      vb.memory = 512
      vb.cpus   = 1
      vb.customize ["modifyvm", :id, "--nicpromisc3", "allow-all"]  # OPT1
      vb.customize ["modifyvm", :id, "--nicpromisc4", "allow-all"]  # OPT2
      vb.customize ["modifyvm", :id, "--nicpromisc5", "allow-all"]  # OPT3
      vb.customize ["modifyvm", :id, "--nicpromisc6", "allow-all"]  # OPT4
    end

    # NIC 2: mgmt/LAN — host-only
    pf.vm.network "private_network",
      ip:                 PFSENSE_MGMT,
      virtualbox__intnet: false

    # NIC 3: OPT1 — vlan10
    pf.vm.network "private_network",
      ip:                 PFSENSE_VLAN10,
      virtualbox__intnet: NET_VLAN10

    # NIC 4: OPT2 — vlan20
    pf.vm.network "private_network",
      ip:                 PFSENSE_VLAN20,
      virtualbox__intnet: NET_VLAN20

    # NIC 5: OPT3 — vlan30
    pf.vm.network "private_network",
      ip:                 PFSENSE_VLAN30,
      virtualbox__intnet: NET_VLAN30

    # NIC 6: OPT4 — vlan40
    pf.vm.network "private_network",
      ip:                 PFSENSE_VLAN40,
      virtualbox__intnet: NET_VLAN40

    pf.vm.provision "file",
      source:      "provision/pfsense_config.xml",
      destination: "/cf/conf/config.xml"

    pf.vm.provision "shell",
      path:       "provision/pfsense.sh",
      privileged: true
  end

  # ==========================================================================
  # dc01 — Windows Server 2022 Standard Core — Domain Controller
  #
  # Boots first (primary, order 1).  Pass 1 installs AD DS and reboots.
  # Pass 2 (run: "never") must be invoked manually after reboot.
  # ==========================================================================
  config.vm.define "dc01", primary: true do |dc|
    dc.vm.box      = "gusztavvargadr/windows-server-2022-standard-core"
    dc.vm.box_version = "2309.0.2402"
    dc.vm.hostname = "dc01"
    dc.vm.synced_folder ".", "/vagrant", disabled: true

    dc.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-dc01"
      vb.memory = 4096
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--vram",        "16"]
      vb.customize ["modifyvm", :id, "--clipboard",   "disabled"]
      vb.customize ["modifyvm", :id, "--draganddrop", "disabled"]
    end

    dc.vm.network "private_network",
      ip:                 DC01_IP,
      virtualbox__intnet: NET_VLAN10

    dc.vm.provision "shell",
      name:       "dc01-pass1",
      path:       "provision/dc01.ps1",
      privileged: true,
      env: {
        "PROVISION_PASS" => "1",
        "DC_IP"          => DC01_IP,
        "VLAN10_GW"      => PFSENSE_VLAN10,
      }

    dc.vm.provision "shell",
      name:       "dc01-pass2",
      run:        "never",
      path:       "provision/dc01.ps1",
      privileged: true,
      env: {
        "PROVISION_PASS" => "2",
        "DC_IP"          => DC01_IP,
        "VLAN10_GW"      => PFSENSE_VLAN10,
      }
  end

  # ==========================================================================
  # adminws — Windows 10 — Admin workstation (hradmin, Domain Admin)
  #
  # Domain join requires dc01-pass2 to be complete first.
  # Pass 1 sets IP + hostname + initiates join (triggers reboot).
  # Pass 2 (adminws-join, run: "never") runs post-reboot.
  # ==========================================================================
  config.vm.define "adminws" do |aw|
    aw.vm.box      = "gusztavvargadr/windows-10"
    aw.vm.hostname = "adminws"
    aw.vm.synced_folder ".", "/vagrant", disabled: true

    aw.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-adminws"
      vb.memory = 2048
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--vram",        "16"]
      vb.customize ["modifyvm", :id, "--clipboard",   "disabled"]
      vb.customize ["modifyvm", :id, "--draganddrop", "disabled"]
    end

    aw.vm.network "private_network",
      ip:                 ADMINWS_IP,
      virtualbox__intnet: NET_VLAN10

    aw.vm.provision "shell",
      name:       "adminws-pass1",
      path:       "provision/adminws.ps1",
      privileged: true,
      env: {
        "PROVISION_PASS" => "1",
        "HOST_IP"        => ADMINWS_IP,
        "VLAN10_GW"      => PFSENSE_VLAN10,
        "DC_IP"          => DC01_IP,
      }

    aw.vm.provision "shell",
      name:       "adminws-join",
      run:        "never",
      path:       "provision/adminws.ps1",
      privileged: true,
      env: {
        "PROVISION_PASS" => "2",
        "HOST_IP"        => ADMINWS_IP,
        "VLAN10_GW"      => PFSENSE_VLAN10,
        "DC_IP"          => DC01_IP,
      }
  end

  # ==========================================================================
  # userws — Windows 10 — User workstation (jsmith, Domain User)
  # ==========================================================================
  config.vm.define "userws" do |uw|
    uw.vm.box      = "gusztavvargadr/windows-10"
    uw.vm.hostname = "userws"
    uw.vm.synced_folder ".", "/vagrant", disabled: true

    uw.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-userws"
      vb.memory = 2048
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--vram",        "16"]
      vb.customize ["modifyvm", :id, "--clipboard",   "disabled"]
      vb.customize ["modifyvm", :id, "--draganddrop", "disabled"]
    end

    uw.vm.network "private_network",
      ip:                 USERWS_IP,
      virtualbox__intnet: NET_VLAN10

    uw.vm.provision "shell",
      name:       "userws-pass1",
      path:       "provision/userws.ps1",
      privileged: true,
      env: {
        "PROVISION_PASS" => "1",
        "HOST_IP"        => USERWS_IP,
        "VLAN10_GW"      => PFSENSE_VLAN10,
        "DC_IP"          => DC01_IP,
      }

    uw.vm.provision "shell",
      name:       "userws-join",
      run:        "never",
      path:       "provision/userws.ps1",
      privileged: true,
      env: {
        "PROVISION_PASS" => "2",
        "HOST_IP"        => USERWS_IP,
        "VLAN10_GW"      => PFSENSE_VLAN10,
        "DC_IP"          => DC01_IP,
      }
  end

  # ==========================================================================
  # privdns — Ubuntu 22.04 — Internal authoritative DNS
  #
  # Serves neutron.local to VLAN10/20/30 and VPN clients.
  # REFUSES queries from VLAN40 (external simulation segment).
  # ==========================================================================
  config.vm.define "privdns" do |pd|
    pd.vm.box      = "gusztavvargadr/ubuntu-server-2204"
    pd.vm.hostname = "privdns"
    pd.vm.synced_folder ".", "/vagrant", disabled: true

    pd.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-privdns"
      vb.memory = 512
      vb.cpus   = 1
    end

    pd.vm.network "private_network",
      ip:                 PRIVDNS_IP,
      virtualbox__intnet: NET_VLAN10

    pd.vm.provision "shell",
      path:       "provision/privdns.sh",
      privileged: true,
      env: {
        "HOST_IP"   => PRIVDNS_IP,
        "VLAN10_GW" => PFSENSE_VLAN10,
        "DC_IP"     => DC01_IP,
      }
  end

  # ==========================================================================
  # containers — Ubuntu 22.04 — Docker Compose multi-service host
  #
  # Runs all web/database/file services as containers:
  #   corpweb    :80/:443   — company landing page (PUBLIC)
  #   esite      :8080/:8443 — SQLi e-commerce (PUBLIC)
  #   odoo       :8069      — ERP, default creds (INTERNAL — firewall blocks)
  #   nextcloud  :9000      — file sharing (INTERNAL — firewall blocks)
  #   mysql      :3306      — empty root password
  #   redis      :6379      — no-auth Redis
  #   nfs        :2049      — world-readable /srv/files (host-level)
  # ==========================================================================
  config.vm.define "containers" do |ct|
    ct.vm.box      = "gusztavvargadr/ubuntu-server-2204"
    ct.vm.hostname = "containers"
    ct.vm.synced_folder ".", "/vagrant", disabled: true

    ct.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-containers"
      vb.memory = 4096
      vb.cpus   = 2
    end

    ct.vm.network "private_network",
      ip:                 CONTAINERS_IP,
      virtualbox__intnet: NET_VLAN20

    ct.vm.provision "shell",
      path:       "provision/containers.sh",
      privileged: true,
      env: {
        "HOST_IP"   => CONTAINERS_IP,
        "VLAN20_GW" => PFSENSE_VLAN20,
        "DC_IP"     => DC01_IP,
      }
  end

  # ==========================================================================
  # pubdns — Ubuntu 22.04 — DMZ public DNS resolver
  #
  # No neutron.local zone — returns NXDOMAIN for all internal names.
  # Forwards everything else to 8.8.8.8.
  # Used by remoteuser (VLAN40) before VPN connects.
  # ==========================================================================
  config.vm.define "pubdns" do |pu|
    pu.vm.box      = "gusztavvargadr/ubuntu-server-2204"
    pu.vm.hostname = "pubdns"
    pu.vm.synced_folder ".", "/vagrant", disabled: true

    pu.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-pubdns"
      vb.memory = 512
      vb.cpus   = 1
    end

    pu.vm.network "private_network",
      ip:                 PUBDNS_IP,
      virtualbox__intnet: NET_VLAN30

    pu.vm.provision "shell",
      path:       "provision/pubdns.sh",
      privileged: true,
      env: {
        "HOST_IP"   => PUBDNS_IP,
        "VLAN30_GW" => PFSENSE_VLAN30,
      }
  end

  # ==========================================================================
  # jumpbox — Ubuntu 22.04 — SSH + xRDP jump host in DMZ
  #
  # SSH password auth enabled (ssh_brute target).
  # Contains saved domain credentials (postex finding).
  # ==========================================================================
  config.vm.define "jumpbox" do |jb|
    jb.vm.box      = "gusztavvargadr/ubuntu-server-2204"
    jb.vm.hostname = "jumpbox"
    jb.vm.synced_folder ".", "/vagrant", disabled: true

    jb.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-jumpbox"
      vb.memory = 2048   # xRDP + xfce4 desktop needs ~1.5 GB minimum
      vb.cpus   = 1
    end

    jb.vm.network "private_network",
      ip:                 JUMPBOX_IP,
      virtualbox__intnet: NET_VLAN30

    jb.vm.provision "shell",
      path:       "provision/jumpbox.sh",
      privileged: true,
      env: {
        "HOST_IP"    => JUMPBOX_IP,
        "VLAN30_GW"  => PFSENSE_VLAN30,
        "DC_IP"      => DC01_IP,
        "PUBDNS_IP"  => PUBDNS_IP,
      }
  end

  # ==========================================================================
  # vpn — Ubuntu 22.04 — OpenVPN concentrator
  #
  # Certificate-based auth only (no password spray).
  # Client cert bundle left world-readable (postex finding).
  # Pushes privdns (172.16.10.53) as DNS to connecting clients.
  # ==========================================================================
  config.vm.define "vpn" do |vp|
    vp.vm.box      = "gusztavvargadr/ubuntu-server-2204"
    vp.vm.hostname = "vpn"
    vp.vm.synced_folder ".", "/vagrant", disabled: true

    vp.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-vpn"
      vb.memory = 512
      vb.cpus   = 1
    end

    vp.vm.network "private_network",
      ip:                 VPN_IP,
      virtualbox__intnet: NET_VLAN30

    vp.vm.provision "shell",
      path:       "provision/vpn.sh",
      privileged: true,
      env: {
        "HOST_IP"    => VPN_IP,
        "VLAN30_GW"  => PFSENSE_VLAN30,
        "PRIVDNS_IP" => PRIVDNS_IP,
      }
  end

  # ==========================================================================
  # remoteuser — Ubuntu 22.04 — External user simulation (VLAN40)
  #
  # Uses pubdns before VPN — neutron.local is NXDOMAIN.
  # Pre-configured OpenVPN client; cert bundle fetched from vpn host.
  # After VPN connect: routes to VLAN10/20/30, DNS switches to privdns.
  # ==========================================================================
  config.vm.define "remoteuser" do |ru|
    ru.vm.box      = "gusztavvargadr/ubuntu-server-2204"
    ru.vm.hostname = "remoteuser"
    ru.vm.synced_folder ".", "/vagrant", disabled: true

    ru.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-remoteuser"
      vb.memory = 512
      vb.cpus   = 1
    end

    ru.vm.network "private_network",
      ip:                 REMOTEUSER_IP,
      virtualbox__intnet: NET_VLAN40

    ru.vm.provision "shell",
      path:       "provision/remoteuser.sh",
      privileged: true,
      env: {
        "HOST_IP"    => REMOTEUSER_IP,
        "VLAN40_GW"  => PFSENSE_VLAN40,
        "PUBDNS_IP"  => PUBDNS_IP,
        "VPN_IP"     => VPN_IP,
      }
  end

  # ==========================================================================
  # kali — Kali Linux rolling — attacker machine (VLAN40)
  #
  # autopwn.py runs from here.  Pre-VPN position: sees only VLAN40 and
  # public-facing VLAN20 ports.  Post-VPN: full internal access.
  # ==========================================================================
  config.vm.define "kali" do |ka|
    ka.vm.box      = "kalilinux/rolling"
    ka.vm.hostname = "kali"
    ka.vm.synced_folder ".", "/vagrant", disabled: true

    ka.vm.provider "virtualbox" do |vb|
      vb.name   = "neutron-kali"
      vb.memory = 2048
      vb.cpus   = 2
      vb.customize ["modifyvm", :id, "--vram", "32"]
    end

    # NIC 2: vlan40 (external simulation segment)
    ka.vm.network "private_network",
      ip:                 KALI_IP,
      virtualbox__intnet: NET_VLAN40

    ka.vm.provision "shell",
      path:       "provision/kali.sh",
      privileged: true,
      env: {
        "HOST_IP"    => KALI_IP,
        "VLAN40_GW"  => PFSENSE_VLAN40,
        "DC_IP"      => DC01_IP,
        "PUBDNS_IP"  => PUBDNS_IP,
      }
  end

end
